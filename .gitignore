.pio
# Native idf.py build output (scripts/build.py uses build/<board>/). Also the
# root sdkconfig a bare `idf.py` would generate; real defaults are sdkconfig.*.
/build/
/sdkconfig
sdkconfig.gezipai
sdkconfig.bh4tdv
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
managed_components
# dependencies.lock is per-target (target + idf version + manifest hash). This
# tree builds 3 targets (gezipai/bh4tdv on esp32s3 via PlatformIO, s31_korvo on
# esp32s31 natively), so a single committed lock always mismatches 2 of them and
# forces a recreate. Let each build generate its own instead of committing one.
dependencies.lock
components/lvgl
__pycache__/
*.map
web-flasher/firmware/*.bin
web-flasher/firmware/bh4tdv/*.bin
web-flasher/firmware/gezipai/*.bin
# manifests are regenerated by scripts/stage_web_flasher.py from the build output
web-flasher/manifest-*.json

web-flasher/index.html
.claude/settings.json
web-flasher.tgz
scripts/cache/
/sdkconfig.old
