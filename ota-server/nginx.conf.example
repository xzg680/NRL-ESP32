server {
    listen 443 ssl http2;
    server_name ota.nrlptt.com;

    root /nrlota/www;
    index index.html;

    # All API, firmware-package, and web-flasher requests use one dynamic path.
    # The trailing slash strips /nrlota/api/ before forwarding to Go.
    location ^~ /nrlota/api/ {
        proxy_pass http://127.0.0.1:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Everything else is a static Vue asset or SPA route.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
